# Required ----------------------------------------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Shared password for the front door. Anyone who uses the app types this once.
# Required in production — the server refuses to start without it.
SHARED_PASSWORD=

# 32+ char random string used to sign the gate cookie. Keep secret.
# Generate with: openssl rand -hex 32
# Required in production — the server refuses to start without it.
COOKIE_SECRET=

# How long the gate cookie stays valid after a successful login (ms).
# Default: 30 days.
# COOKIE_MAX_AGE_MS=2592000000

# Optional ----------------------------------------------------------------
# Override the default model
ANTHROPIC_MODEL=claude-sonnet-4-5

# Max tokens per response
ANTHROPIC_MAX_TOKENS=4096

# Server port (defaults to 3001)
PORT=3001

# Production: where the built frontend lives. Defaults to "dist".
DIST_DIR=dist

# If serving the frontend from a different origin, list allowed origins (comma-separated).
# CORS_ORIGINS=https://app.example.com,https://example.com

# Set to 1 if running behind a reverse proxy that sets X-Forwarded-* headers.
# TRUST_PROXY=1

# Request limits -----------------------------------------------------------
# JSON body limit for all endpoints. Chat payloads are small; keep this tight.
# BODY_LIMIT=256kb

# Rate limiting on /api/chat (per IP, fixed window).
# Defaults: enabled in production, disabled in development.
# RATE_LIMIT_ENABLE=1
# RATE_LIMIT_WINDOW_MS=600000   # 10 minutes
# RATE_LIMIT_MAX=30

# Chat payload caps (characters; requests above these are rejected before
# any upstream call to Anthropic).
# CHAT_MAX_SYSTEM_CHARS=32000
# CHAT_MAX_MESSAGES=100
# CHAT_MAX_MESSAGE_CHARS=32000
